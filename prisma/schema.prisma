generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Language {
  english
  urdu
  arabic
  sindhi
}

enum Difficulty {
  beginner
  intermediate
  advanced
}

enum TestStatus {
  PASSED
  FAILED
  INCOMPLETE
}

enum CertificateRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  password            String
  role                Role                 @default(USER)
  isBanned            Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  typingTests         TypingTest[]
  certificateRequests CertificateRequest[]
  certificates        Certificate[]
  approvedRequests    CertificateRequest[] @relation("ApprovedBy")
}

model TypingTest {
  id                  String               @id @default(cuid())
  userId              String
  language            Language
  wpm                 Float
  accuracy            Float
  mistakes            Int
  correctChars        Int
  incorrectChars      Int
  totalChars          Int
  duration            Int
  status              TestStatus
  paragraphId         String?
  createdAt           DateTime             @default(now())
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  paragraph           TypingParagraph?     @relation(fields: [paragraphId], references: [id])
  certificateRequest  CertificateRequest?
  certificate         Certificate?
}

model CertificateRequest {
  id           String                   @id @default(cuid())
  userId       String
  testId       String                   @unique
  status       CertificateRequestStatus @default(PENDING)
  approvedById String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  test         TypingTest               @relation(fields: [testId], references: [id], onDelete: Cascade)
  approvedBy   User?                    @relation("ApprovedBy", fields: [approvedById], references: [id])
  certificate  Certificate?
}

model Certificate {
  id                String             @id @default(cuid())
  certificateNumber String             @unique
  userId            String
  testId            String             @unique
  requestId         String             @unique
  imageUrl          String?
  issuedAt          DateTime           @default(now())
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  test              TypingTest         @relation(fields: [testId], references: [id], onDelete: Cascade)
  request           CertificateRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model TypingParagraph {
  id          String      @id @default(cuid())
  language    Language
  difficulty  Difficulty
  content     String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  typingTests TypingTest[]
}

model TestConfig {
  id          String   @id @default(cuid())
  minWpm      Float    @default(35)
  minAccuracy Float    @default(90)
  maxMistakes Int      @default(10)
  updatedAt   DateTime @updatedAt
}
